{
  "manifest_version": 3,
  "name": "CricShield — Smart Ad Overlay",
  "description": "Replaces streaming ads with a live cricket scoreboard overlay. Shows REAL live scores from CricAPI.",
  "version": "1.1.0",
  "icons": {
    "16": "public/icons/icon-16.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.jiocinema.com/*",
    "*://*.hotstar.com/*",
    "*://*.jiohotstar.com/*",
    "*://*.cricbuzz.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.jiocinema.com/*",
        "*://*.hotstar.com/*",
        "*://*.jiohotstar.com/*"
      ],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    },
    "default_title": "CricShield Settings"
  },
  "web_accessible_resources": [
    {
      "resources": ["public/logo.png"],
      "matches": ["*://*.jiocinema.com/*", "*://*.hotstar.com/*", "*://*.jiohotstar.com/*"]
    }
  ]
}
